# --- Database (Neon Postgres). Leave unset for in-memory dev mode. ---
DATABASE_URL=

# --- Email (Resend). Unset = emails logged to console. ---
RESEND_API_KEY=
EMAIL_FROM="SEGC <plan@southeasterngc.com>"

# --- Slack sales alerts. Unset = alerts logged to console. ---
SLACK_WEBHOOK_URL=

# --- HubSpot CRM. Unset = upserts logged to console. ---
HUBSPOT_TOKEN=

# --- Cloudflare R2 (S3-compatible) for generated PDFs. Unset = PDFs kept as data URLs / skipped. ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=segc-build-planner
R2_PUBLIC_BASE_URL=

# --- Inngest (background jobs). Unset in dev = fulfillment runs inline. ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Cloudflare Turnstile (anti-spam). Unset = validation skipped. ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Analytics (PostHog). Unset = disabled. ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Booking ---
NEXT_PUBLIC_CAL_LINK=
